generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String           @id @unique
  userRole            UserRole         @default(USER)
  createdAt           DateTime         @default(now()) @map("created_at")
  lastLoginAt         DateTime         @default(now()) @map("last_login_at")
  userAccessStatus    UserAccessStatus @default(NORMAL)
  imageUsedCountTotal Int              @default(0)
  imageUsedCountToday Int              @default(0)
  lastResetDate       DateTime         @default(now())
  isTOSAgreed         Boolean          @default(false)

  @@index([userAccessStatus])
  @@index([id, userAccessStatus])
  @@index([createdAt])
}

model ImageLog {
  id         Int      @id @default(autoincrement())
  imageId    String
  imageGroup String
  userId     String
  createdAt  DateTime @default(now())

  @@index([imageId, imageGroup])
  @@index([imageId])
  @@index([imageGroup])
  @@index([createdAt])
}

model Log {
  id        Int      @id @default(autoincrement())
  userId    String
  createdAt DateTime @default(now())
  level     LogLevel
  event     String
  tag       String
  message   String
  params    Json     @default("{}")

  @@index([createdAt, event])
  @@index([event, tag])
  @@index([createdAt])
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
  FATAL
}

enum UserRole {
  OWNER
  ADMIN
  USER
  USER_A
}

enum UserAccessStatus {
  NORMAL
  SUSPENDED
}
